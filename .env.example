# Server
NODE_ENV=development
PORT=3333

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mei_finance?schema=public

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.meifinance.com.br
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# MEI — limite anual de faturamento (R$), definido por legislação
MEI_ANNUAL_LIMIT=81000
MEI_ALERT_THRESHOLD_PERCENT=80
