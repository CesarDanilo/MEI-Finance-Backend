generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String

  transactions  Transaction[]
  categories    Category[]
  refreshTokens RefreshToken[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model Category {
  id        String         @id @default(uuid())
  name      String
  type      CategoryType
  color     String?
  icon      String?

  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime       @default(now())

  @@map("categories")
}

model Transaction {
  id              String           @id @default(uuid())
  type            TransactionType
  amount          Decimal          @db.Decimal(10, 2)
  description     String?
  transactionDate DateTime

  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("transactions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}